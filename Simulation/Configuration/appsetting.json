{
    "VisulationParams":
    {
        "title":"Differential Drive Robot Simulation",
        "xlabel":"x-axis",
        "ylabel":"y-axis",
        "grid_on":true,
        "xlim": [-3,3],
        "ylim": [-3,3],
        "step": 0.05,
        "Patches":[
            {
                "applyToVisualFunction": "MoveRectangle",
                "patch": "Rectangle",
                "patchName" : "DifferentialDriveRobot",
                "arguments":{
                    "xy": [0.0,0.0],
                    "rotation_point": "center",
                    "width" : 0.6,
                    "height" : 0.3,
                    "linewidth": 0.5,
                    "edgecolor": "blue",
                    "facecolor": "blue"
                }
            },
            {
                "applyToVisualFunction": "SetTarget",
                "patch": "Rectangle",
                "patchName" :"TargetRectangle",
                "arguments":{
                    "xy": [1.5,1.5],
                    "rotation_point": "center",
                    "angle":45.0,
                    "width" : 0.6,
                    "height" : 0.3,
                    "linewidth": 0.5,
                    "edgecolor": "red",
                    "facecolor": "red"
                }
            }
        ]

    },
    "DiffDriveParams":
    {
        "Name": "r2d2",
        "N":3,
        "M":2,
        "s":0.75,
        "r":0.25
    },
    "LoggerSettings":
    {
        "Directory": "Existing folder path",
        "CaptureSettings":
        {
            "Erros": true,
            "Warnings": true,
            "Exceptions": true,
            "ObjectStateFrequency": "Every timelapse of object that you want to capture in seconds, e.g the result state change in a trajectory optimization" 
        }
    }
}